# WandbLogger
WANDB_API_KEY=your_api_key_here
WANDB_ENTITY=your_username_or_team
# optional, overrides constructor
WANDB_PROJECT=your_project_name

# Optional: pin the boileroom image tag used for Modal and Apptainer backends.
# Must be set BEFORE importing bagel/boileroom (the Modal image is locked at import time).
# BOILEROOM_IMAGE_TAG=cuda12.6-alpha.1
